---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { getCollection } from "astro:content";
import "../../styles/blog.css";

type BlogPost = CollectionEntry<"blog">;

const posts = await getCollection("blog", (post: BlogPost) => {
  return post.data.draft !== true;
});

const sortedPosts = posts.sort((a: BlogPost, b: BlogPost) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

const featuredPost = sortedPosts[0] ?? null;
const otherPosts = sortedPosts.slice(1);

const formattedFeaturedPostDate = featuredPost
  ? featuredPost.data.date
      .toLocaleDateString("it-IT", {
        month: "short",
        year: "numeric",
      })
      .replace(".", "")
  : "";

const articlesCountLabel =
  sortedPosts.length === 1
    ? "01 articolo"
    : `${String(sortedPosts.length).padStart(2, "0")} articoli`;
---

<BaseLayout
  title="Blog — Cielo Artuso"
  description="Appunti su web design, sviluppo, portfolio, processi creativi e progetti digitali."
  pageClass="blog-page"
  logoVariant="light"
>
  <header class="list-header">
    <div class="list-header-grid">
      <div class="list-header-info">
        <h1><em>Blog</em></h1>

        <p class="list-intro">
          Appunti, riflessioni e spiegazioni semplici su sviluppo web.
        </p>

        <span class="count">{articlesCountLabel}</span>

        <div class="filters">
          <button class="filter active" data-cat="tutti">tutti</button>
          <button class="filter" data-cat="progetti">progetti</button>
        </div>
      </div>

      {featuredPost && (
        <a
          href={`/blog/${featuredPost.id}`}
          class="featured-article"
          data-cat={featuredPost.data.tag}
        >
          {featuredPost.data.cover && (
            <div class="featured-img">
              <img
                src={featuredPost.data.cover}
                alt={featuredPost.data.title}
              />
            </div>
          )}

          <div class="featured-content">
            <div class="featured-meta">
              <span>{formattedFeaturedPostDate}</span>
              {featuredPost.data.tag && <span>{featuredPost.data.tag}</span>}
            </div>

            <h2
              set:html={featuredPost.data.displayTitle ?? featuredPost.data.title}
            ></h2>
          </div>
        </a>
      )}
    </div>
  </header>

  <main class="articles">
    {otherPosts.map((post: BlogPost) => (
      <ArticleCard post={post} />
    ))}
  </main>
</BaseLayout>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter");
  const articles = document.querySelectorAll<HTMLElement>(
    ".article-row, .featured-article"
  );

  filters.forEach((button) => {
    button.addEventListener("click", () => {
      filters.forEach((filter) => filter.classList.remove("active"));
      button.classList.add("active");

      const selectedCategory = button.dataset.cat;

      articles.forEach((article) => {
        const articleCategory = article.dataset.cat;

        const shouldShow =
          selectedCategory === "tutti" || articleCategory === selectedCategory;

        article.style.display = shouldShow ? "" : "none";
      });
    });
  });
</script>